# ─── MLS ──────────────────────────────────────────────────────
# Obtain these from GPRMLS after signing the IDX data agreement.
# Contact: support@gprmls.com

GPRMLS_TOKEN_URL=https://auth.gprmls.com/connect/token
GPRMLS_BASE_URL=https://api.gprmls.com/reso/odata
GPRMLS_CLIENT_ID=
GPRMLS_CLIENT_SECRET=

# The ListAgentMlsId value on Aaron's listings (confirm with GPRMLS)
AGENT_MLS_ID=NE-45821

# ─── Cache (Upstash Redis) ─────────────────────────────────────
# Create a free database at upstash.com → copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MLS listing cache TTL in seconds (5 min default)
LISTING_CACHE_TTL=300

# ─── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Set the same value as VITE_API_KEY / NG_APP_API_KEY in the frontend project.
API_KEY=

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:4200,https://yourdomain.com

# ─── AI Chat (Gemini) ──────────────────────────────────────────
# Get your API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_key_here

# Address that receives lead notification emails
# Local dev: use your own email (Resend free tier sends to verified address only)
# Production: aaron@krierrealty.com
LEAD_NOTIFY_EMAIL=you@youremail.com

# From address — must be from a Resend-verified domain in production
# For local testing use: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL: Transaction Pooler URL (port 6543) — used at runtime
#   e.g. postgresql://postgres.abcdefgh:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# DATABASE_DIRECT_URL: Direct connection (port 5432) — used only for drizzle-kit migrations
#   e.g. postgresql://postgres:[password]@db.abcdefgh.supabase.co:5432/postgres

DATABASE_URL=
DATABASE_DIRECT_URL=

# Alternative: individual PG* vars (avoids URL-parsing issues with special chars in passwords)
# Set these in Vercel instead of DATABASE_URL if your password contains @, #, !, etc.
# Use the Transaction Pooler host (port 6543) for runtime, Direct host (port 5432) for migrations.
# PGHOST=aws-0-us-east-1.pooler.supabase.com
# PGPORT=6543
# PGUSER=postgres.YOUR_PROJECT_REF
# PGPASSWORD=your_password
# PGDATABASE=postgres

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Base URL of the frontend — used to build admin deep-links in lead notification emails
# Local: http://localhost:4200   Production: https://krierrealty.com
ADMIN_BASE_URL=http://localhost:4200
# Supabase project URL — used to fetch JWKS for JWT verification
# From Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxx.supabase.co

# Comma-separated list of emails allowed to access the admin portal
ADMIN_EMAILS=aaron@krierrealty.com,you@example.com
