{
  "name": "real-estate-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "NODE_ENV=development tsx --env-file=.env src/db/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "@supabase/supabase-js": "^2.99.1",
    "@upstash/redis": "^1.34.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.5",
    "jose": "^6.2.1",
    "pg": "^8.20.0",
    "resend": "^6.9.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
